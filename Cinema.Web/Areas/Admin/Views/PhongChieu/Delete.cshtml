@model Cinema.DTO.PhongChieuDTO
@{
    ViewData["Title"] = "Xóa phòng chiếu";
}

<div class="card shadow border-0 rounded-4 w-50 mx-auto border-danger">
    <div class="card-header bg-danger text-white py-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-trash me-2"></i> Xác nhận xóa phòng chiếu</h5>
    </div>
    <div class="card-body p-4 text-center">
        <i class="bi bi-exclamation-triangle-fill text-warning display-1"></i>
        <h4 class="mt-3">Bạn có chắc chắn muốn xóa phòng chiếu này?</h4>
        <p class="text-muted">Hành động này sẽ xóa toàn bộ dữ liệu ghế ngồi của phòng chiếu. Không thể hoàn tác!</p>

        <div class="alert alert-light border text-start mt-4">
            <p><strong>Mã Phòng:</strong> @Model.MaPhong</p>
            <p><strong>Tên Phòng:</strong> @Model.TenPhong</p>
            <p><strong>Sức chứa:</strong> @Model.SucChua ghế (@Model.SoGheDaTao ghế đã sinh ra)</p>
            <p><strong>Loại Phòng:</strong> @Model.LoaiPhong</p>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="MaPhong" />
            <a asp-action="Index" class="btn btn-secondary me-2 px-4">Hủy</a>
            <button type="submit" class="btn btn-danger px-4">Xác nhận xóa</button>
        </form>
    </div>
</div>
