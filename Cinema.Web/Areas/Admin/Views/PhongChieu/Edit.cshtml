@model Cinema.DTO.PhongChieuDTO
@{
    ViewData["Title"] = "Cập nhật phòng chiếu";
}

<div class="card shadow border-0 rounded-4 w-50 mx-auto">
    <div class="card-header bg-warning text-dark py-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-pencil me-2"></i> Cập nhật Phòng Chiếu</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="MaPhong" />

            <div class="mb-3">
                <label asp-for="TenPhong" class="form-label fw-bold">Tên Phòng</label>
                <input asp-for="TenPhong" class="form-control" required />
                <span asp-validation-for="TenPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LoaiPhong" class="form-label fw-bold">Loại Phòng</label>
                <select asp-for="LoaiPhong" class="form-select">
                    <option value="2D">2D</option>
                    <option value="3D">3D</option>
                    <option value="IMAX">IMAX</option>
                </select>
                <span asp-validation-for="LoaiPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SucChua" class="form-label fw-bold">Sức chứa (Ghế)</label>
                <input asp-for="SucChua" type="number" min="1" max="500" class="form-control" required />
                <span asp-validation-for="SucChua" class="text-danger"></span>
                <small class="text-danger">Lưu ý: Nếu thay đổi sức chứa, hệ thống sẽ xóa toàn bộ ghế cũ (nếu chưa có ai đặt) và sinh lại ghế mới.</small>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>
