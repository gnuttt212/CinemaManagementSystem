@model Cinema.DTO.PhimDTO
@{
    ViewData["Title"] = "Thêm Phim Mới";
    Layout = "_Layout";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý phim</a></li>
            <li class="breadcrumb-item active">Thêm mới</li>
        </ol>
    </nav>

    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-plus-circle me-2"></i>THÔNG TIN PHIM MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên phim</label>
                            <input asp-for="TenPhim" class="form-control form-control-lg" placeholder="Ví dụ: Lật Mặt 7" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thể loại</label>
                                <select asp-for="TheLoai" class="form-select">
                                    @foreach (var loai in ViewBag.MaLoaiPhim)
                                    {
                                        <option value="@loai.TenLoai">@loai.TenLoai</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thời lượng (Phút)</label>
                                <input asp-for="ThoiLuong" type="number" class="form-control" placeholder="120" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày khởi chiếu</label>
                                <input asp-for="NgayKhoiChieu" type="date" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Đạo diễn</label>
                                <input asp-for="DaoDien" type="text" class="form-control" placeholder="Tên đạo diễn" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả phim</label>
                            <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Nhập tóm tắt nội dung phim..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-4 text-center border-start">
                        <label class="form-label fw-bold d-block mb-3">Poster Phim</label>

                        <div class="mb-3">
                            <img id="previewImg" src="/images/no-image.jpg"
                                 class="img-thumbnail shadow-sm mb-3"
                                 style="height: 300px; width: 200px; object-fit: cover;" />
                        </div>

                        <div class="input-group mb-3">
                            <input type="file" name="ImageFile" id="imageInput" class="form-control" accept="image/*" />
                        </div>
                        <small class="text-muted d-block mb-4">Lưu ý: Chỉ chấp nhận file ảnh .jpg, .png</small>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">
                                <i class="bi bi-save me-2"></i>Lưu thông tin
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imageInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('previewImg').src = URL.createObjectURL(file);
            }
        };
    </script>
}