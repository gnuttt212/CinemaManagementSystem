@model List<Cinema.DTO.DoAnDTO>

@{
    ViewData["Title"] = "Dịch vụ bắp nước";
}

<!-- HERO BANNER CHO DỊCH VỤ -->
<div class="gsap-hero" style="min-height: 40vh; margin-bottom: 2rem;">
    <div class="gsap-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1572177215152-32f247303126?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80'); filter: brightness(0.4);"></div>
    <div class="gsap-hero-overlay"></div>
    <div class="gsap-hero-content pt-5">
        <h1 class="gsap-hero-title mb-0" style="font-size: clamp(2rem, 4vw, 3.5rem);">
            <span class="line"><span class="line-inner text-white">DỊCH VỤ <span class="highlight">BẮP NƯỚC</span></span></span>
        </h1>
        <p class="gsap-hero-subtitle mt-3 text-white">Thưởng thức bắp rang bơ thơm ngon và nước uống mát lạnh trong suốt bộ phim</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var dv in Model)
            {
                <div class="col-md-3 mb-4 gsap-reveal-scale">
                    <div class="gsap-feature-card h-100 text-center d-flex flex-column justify-content-between p-4">
                        <div>
                            <div class="gsap-feature-icon mx-auto mb-4" style="background: rgba(245,197,24,0.1); color: var(--cinema-accent); border-color: rgba(245,197,24,0.2); width: 80px; height: 80px; font-size: 2.5rem;">
                                <i class="bi bi-cup-straw"></i>
                            </div>
                            <h5 class="fw-bold text-white mb-2">@dv.TenDoAn</h5>
                            <p class="text-muted small mb-3">@(dv.Loai ?? "Chưa phân loại")</p>
                        </div>
                        
                        <div class="mt-3 border-top border-secondary pt-3">
                            <p class="text-warning fs-4 fw-bold mb-0">
                                @dv.Gia.ToString("N0") đ
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 gsap-reveal">
                <i class="bi bi-emoji-frown display-1 text-muted"></i>
                <p class="mt-3 text-muted fs-5">Chưa có dịch vụ nào.</p>
            </div>
        }
    </div>
</div>