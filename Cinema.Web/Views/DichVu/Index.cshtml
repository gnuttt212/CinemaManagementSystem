@model List<Cinema.DTO.DoAnDTO>

@{
    ViewData["Title"] = "Dịch vụ bắp nước";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold text-success mb-4">🍿 DỊCH VỤ BẮP NƯỚC</h2>
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var dv in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 text-center shadow-sm border-0 rounded-4 overflow-hidden">
                        <div class="card-body d-flex flex-column justify-content-center">
                            <div class="mb-3">
                                <i class="bi bi-cup-straw display-3 text-success"></i>
                            </div>
                            <h5 class="card-title fw-bold">@dv.TenDoAn</h5>
                            <p class="text-muted small mb-2">@(dv.Loai ?? "Chưa phân loại")</p>
                            <p class="text-danger fs-5 fw-bold mb-0">
                                @dv.Gia.ToString("N0") đ
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-emoji-frown display-1 text-muted"></i>
                <p class="mt-3 text-muted fs-5">Chưa có dịch vụ nào.</p>
            </div>
        }
    </div>
</div>