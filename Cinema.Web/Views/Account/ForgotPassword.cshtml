@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="gsap-hero" style="min-height: 100vh;">
    <div class="gsap-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1485846234645-a62644f84728?ixlib=rb-1.2.1&auto=format&fit=crop&w=1340&q=80'); filter: brightness(0.2);"></div>
    <div class="glow-orb glow-orb-gold" style="top: -10%; right: -10%;"></div>

    <div class="container position-relative z-2 py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4 gsap-reveal-scale">
                <div class="gsap-auth-card">
                    <div class="text-center mb-5">
                        <h2 class="gsap-section-title mb-2" style="font-size: 2rem;">QUÊN MẬT KHẨU</h2>
                        <p class="text-muted">Nhập email của bạn để nhận liên kết khôi phục mật khẩu</p>
                    </div>

                    <form action="#" method="post">
                        <div class="form-floating mb-4">
                            <input type="email" class="form-control" id="floatingEmail" placeholder="Email" required>
                            <label for="floatingEmail"><i class="bi bi-envelope me-2"></i> Địa chỉ Email</label>
                        </div>

                        <button type="button" class="btn-cinema-primary w-100 py-3 mb-4" style="font-size: 1.1rem;" onclick="alert('Đã gửi yêu cầu khôi phục mật khẩu vào email của bạn!');">
                            GỬI YÊU CẦU
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-controller="Account" asp-action="Login" class="text-muted small text-decoration-none btn-link" style="transition: color 0.3s;">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
