@model Cinema.DTO.KhachHangRegisterRequest

@{
    ViewData["Title"] = "Đăng ký thành viên";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 85vh;">
        <div class="col-md-6">
            <div class="card shadow-lg border-0" style="border-radius: 15px;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-success">TẠO TÀI KHOẢN</h2>
                        <p class="text-muted">Gia nhập cộng đồng người yêu điện ảnh ngay hôm nay</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-octagon-fill"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Register" method="post">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <div class="form-floating">
                                    <input asp-for="HoTen" class="form-control" placeholder="Họ và tên" required>
                                    <label asp-for="HoTen"><i class="bi bi-person-badge"></i> Họ và tên</label>
                                </div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Email" type="email" class="form-control" placeholder="Email" required>
                                    <label asp-for="Email"><i class="bi bi-envelope"></i> Địa chỉ Email</label>
                                </div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <div class="form-floating">
                                    <input asp-for="TaiKhoan" class="form-control" placeholder="Tên đăng nhập" required>
                                    <label asp-for="TaiKhoan"><i class="bi bi-person"></i> Tên đăng nhập</label>
                                </div>
                            </div>

                            <div class="col-md-12 mb-4">
                                <div class="form-floating">
                                    <input asp-for="MatKhau" type="password" class="form-control" placeholder="Mật khẩu" required>
                                    <label asp-for="MatKhau"><i class="bi bi-shield-lock"></i> Mật khẩu</label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm" style="border-radius: 10px;">
                            ĐĂNG KÝ NGAY
                        </button>

                        <div class="text-center mt-4">
                            <p class="small">Đã có tài khoản? <a asp-action="Login" class="text-success fw-bold text-decoration-none">Đăng nhập tại đây</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}