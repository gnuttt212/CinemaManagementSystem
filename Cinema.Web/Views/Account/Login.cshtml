@model Cinema.DTO.KhachHangLoginRequest

@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="gsap-hero" style="min-height: 100vh;">
    <!-- Background image to match cinematic theme -->
    <div class="gsap-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1485846234645-a62644f84728?ixlib=rb-1.2.1&auto=format&fit=crop&w=1340&q=80'); filter: brightness(0.2);"></div>
    <div class="glow-orb glow-orb-red" style="top: -10%; right: -10%;"></div>
    <div class="glow-orb glow-orb-gold" style="bottom: -10%; left: -10%;"></div>

    <div class="container position-relative z-2 py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4 gsap-reveal-scale">
                <div class="gsap-auth-card">
                    <div class="text-center mb-5">
                        <h2 class="gsap-section-title mb-2">CHÀO MỪNG TRỞ LẠI</h2>
                        <p class="text-muted">Đăng nhập để tiếp tục đặt vé</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger bg-danger text-white border-0 alert-dismissible fade show" role="alert" style="background-color: rgba(220, 53, 69, 0.8) !important;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="TaiKhoan" class="form-control" id="floatingInput" placeholder="Tên đăng nhập" required>
                            <label for="floatingInput"><i class="bi bi-person me-2"></i> Tên đăng nhập</label>
                            <span asp-validation-for="TaiKhoan" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="MatKhau" type="password" class="form-control" id="floatingPassword" placeholder="Mật khẩu" required>
                            <label for="floatingPassword"><i class="bi bi-lock me-2"></i> Mật khẩu</label>
                            <span asp-validation-for="MatKhau" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between mb-4 mt-2">
                            <div class="form-check">
                                <input class="form-check-input bg-dark border-secondary" type="checkbox" id="rememberMe">
                                <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="small text-white text-decoration-none border-bottom border-secondary">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn-cinema-primary w-100 py-3 mb-4" style="font-size: 1.1rem;">
                            ĐĂNG NHẬP
                        </button>

                        <div class="position-relative mt-4 mb-4 text-center">
                            <hr class="border-secondary opacity-50">
                            <span class="position-absolute top-50 start-50 translate-middle px-3 text-muted small" style="background: rgba(26, 26, 46, 0.95);">hoặc</span>
                        </div>

                        <a asp-action="GoogleLogin" class="btn-cinema-outline w-100 py-3 mb-4 d-flex justify-content-center align-items-center text-decoration-none">
                            <i class="bi bi-google me-2 text-danger"></i> Đăng nhập bằng Google
                        </a>

                        <div class="text-center">
                            <p class="small text-muted mb-0">
                                Chưa có tài khoản?
                                <a asp-controller="Account" asp-action="Register" class="text-white fw-bold ms-1" style="text-decoration: none; border-bottom: 1px dashed var(--cinema-primary);">
                                    Đăng ký ngay
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
                
                <div class="text-center mt-4 gsap-reveal">
                    <a asp-controller="Home" asp-action="Index" class="text-muted small text-decoration-none btn-link" style="transition: color 0.3s;">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}