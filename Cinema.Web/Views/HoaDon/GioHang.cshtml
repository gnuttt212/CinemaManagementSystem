@model Cinema.DTO.CartItemDTO

<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">XÁC NHẬN ĐƠN HÀNG</h2>
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm p-4 mb-4">
                <h4 class="text-primary"><i class="bi bi-film"></i> @Model.TenPhim</h4>
                <p class="fs-5">Ghế đã chọn: <span class="badge bg-success">@string.Join(", ", Model.DanhSachGhe)</span></p>
                <hr />
                <h5><i class="bi bi-box-seam"></i> Dịch vụ bắp nước:</h5>
                @if (Model.DoAns != null && Model.DoAns.Any())
                {
                    <table class="table table-borderless">
                        <thead>
                            <tr class="border-bottom">
                                <th>Tên dịch vụ</th>
                                <th>Số lượng</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dv in Model.DoAns)
                            {
                                <tr>
                                    <td>@dv.TenDoAn</td>
                                    <td>x @dv.SoLuong</td>
                                    <td class="text-end">@((dv.Gia * dv.SoLuong).ToString("N0")) đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">Bạn không chọn dịch vụ bắp nước nào.</p>
                }
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-white p-4 shadow">
                <h4 class="text-center">TỔNG CỘNG</h4>
                <hr />
                <div class="d-flex justify-content-between mb-2">
                    <span>Tiền vé:</span>
                    <span>@Model.TongTienPhim.ToString("N0") đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Tiền dịch vụ:</span>
                    <span>@((Model.TongTien - Model.TongTienPhim).ToString("N0")) đ</span>
                </div>
                <div class="border-top pt-3">
                    <h2 class="text-warning text-center fw-bold">@Model.TongTien.ToString("N0") đ</h2>
                </div>
                <button onclick="xacNhanThanhToan()" class="btn btn-warning btn-lg w-100 mt-4 fw-bold py-3">
                    XÁC NHẬN THANH TOÁN
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function xacNhanThanhToan() {
            if (confirm("Hệ thống sẽ tiến hành lưu hóa đơn và đặt vé. Bạn chắc chắn chứ?")) {
                $.post('/HoaDon/XacNhanThanhToan', function (res) {
                    if (res.success) {
                        window.location.href = '/HoaDon/ThanhToanThanhCong?id=' + res.maHD;
                    } else {
                        alert("Lỗi: " + res.message);
                    }
                }).fail(function () {
                    alert("Không thể kết nối tới máy chủ. Vui lòng thử lại!");
                });
            }
        }
    </script>
}