@{
    ViewData["Title"] = "Thanh toán thất bại";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-lg border-0 rounded-4 p-5">
                <div class="mb-4">
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold text-danger mb-3">Thanh toán không thành công</h2>
                <p class="text-muted fs-5 mb-4">@ViewBag.Message</p>

                <div class="alert alert-warning text-start">
                    <i class="bi bi-info-circle me-2"></i>
                    Hóa đơn của bạn đã được lưu với trạng thái <strong>"Chờ thanh toán"</strong>.
                    Bạn có thể thử thanh toán lại hoặc liên hệ nhân viên hỗ trợ.
                </div>

                <div class="d-flex justify-content-center gap-3 mt-3">
                    <a asp-controller="Phim" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4">
                        <i class="bi bi-house me-2"></i> Về trang chủ
                    </a>
                    <a asp-controller="NguoiDung" asp-action="Profile" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                        <i class="bi bi-person me-2"></i> Hồ sơ của tôi
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
