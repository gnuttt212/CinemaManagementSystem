@model Cinema.DTO.HoaDonDTO
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                <h2 class="fw-bold mt-2 text-success">THANH TOÁN THÀNH CÔNG!</h2>
                <p class="text-muted">Mã hóa đơn: <span class="fw-bold">#@Model.MaHD</span></p>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden position-relative">
                <div class="bg-primary p-3 text-white">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-ticket-perforated me-2"></i>VÉ XEM PHIM ĐIỆN TỬ</h5>
                </div>
                <div class="card-body p-4 text-start">
                    <div class="mb-3">
                        <label class="small text-muted text-uppercase">Phim</label>
                        <h4 class="fw-bold text-primary">@Model.TenPhim</h4>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="small text-muted text-uppercase">Suất chiếu</label>
                            <p class="mb-0 fw-bold text-dark">@Model.SuatChieu</p>
                        </div>
                        <div class="col-6">
                            <label class="small text-muted text-uppercase">Ghế</label>
                            <p class="mb-0 fw-bold text-danger">@string.Join(", ", Model.DanhSachGhe)</p>
                        </div>
                    </div>

                    <hr style="border-top: 2px dashed #ccc;">

                    <div class="text-center py-2">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=CINEMATICKET_@Model.MaHD"
                             alt="QR Code" class="img-thumbnail border-0 shadow-sm">
                        <p class="small text-muted mt-3 mb-0">Vui lòng đưa mã này cho nhân viên để quét vé</p>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 py-3">
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-controller="Phim" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Về trang chủ</a>
                        <a asp-controller="NguoiDung" asp-action="Profile" class="btn btn-primary rounded-pill px-4">Xem lịch sử</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>