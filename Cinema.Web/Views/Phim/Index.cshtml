@model IEnumerable<Cinema.DTO.PhimDTO>

@{
    ViewData["Title"] = "Trang chủ - Cinema";
}

<div class="container mt-4">
    <h1 class="text-center mb-4 text-uppercase fw-bold text-primary">
        <i class="bi bi-film"></i> Lịch Chiếu Phim
    </h1>

    <div class="d-flex justify-content-center flex-wrap mb-5 gap-2">
        @for (int i = 0; i < 7; i++)
        {
            var d = DateTime.Today.AddDays(i);
            bool isActive = false;
            
            if (ViewBag.SelectedDate != null)
            {
                isActive = ((DateTime)ViewBag.SelectedDate).Date == d.Date;
            }
            else
            {
                isActive = i == 0;
            }

            var activeClass = isActive ? "btn-primary shadow-sm" : "btn-outline-primary border-2 opacity-75";
            
            <a asp-action="Index" asp-route-date="@d.ToString("yyyy-MM-dd")" class="btn @activeClass fw-bold rounded-4 px-4 py-2 text-center" style="min-width: 100px;">
                <div class="fs-5">@d.ToString("dd/MM")</div>
                <small class="fw-normal d-block mt-1">
                    @(i == 0 ? "Hôm nay" : d.ToString("dddd", new System.Globalization.CultureInfo("vi-VN")))
                </small>
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted"><i class="bi bi-calendar-x"></i> Không có suất chiếu nào trong ngày hôm nay.</h4>
            <p>Vui lòng chọn ngày khác để xem lịch chiếu.</p>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 15px; overflow: hidden;">
                    <div style="position: relative;">
                        @{
                            var imgUrl = string.IsNullOrEmpty(item.Poster)
                            ? "https://via.placeholder.com/300x400?text=No+Image"
                            : item.Poster.StartsWith("http") ? item.Poster : "/images/phim/" + item.Poster;
                        }
                        <img src="@imgUrl" class="card-img-top" alt="@item.TenPhim" style="height: 400px; object-fit: cover;" onerror="this.onerror=null; this.src='https://via.placeholder.com/300x400?text=No+Image';">
                    </div>

                    <div class="card-body">
                        <h5 class="card-title fw-bold text-truncate text-primary">@item.TenPhim</h5>
                        <p class="text-secondary small mb-2"><i class="bi bi-tags-fill text-warning me-1"></i> @item.TheLoai</p>
                        <div class="mt-3">
                            @if (item.DanhSachLichChieu != null && item.DanhSachLichChieu.Any())
                            {
                                <p class="small text-muted mb-2"><i class="bi bi-calendar3"></i> Lịch chiếu:</p>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var suat in item.DanhSachLichChieu)
                                    {
                                        <a asp-controller="Phim" asp-action="ChonGhe" asp-route-maLich="@suat.MaLich"
                                           class="btn btn-outline-primary btn-sm fw-bold px-3 py-1 shadow-sm">
                                            @suat.GioChieu
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="py-2">
                                    <span class="badge bg-light text-secondary border">
                                        <i class="bi bi-calendar-x"></i> Sắp có suất chiếu
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a asp-action="Details" asp-route-id="@item.MaPhim" class="btn btn-outline-secondary w-100 btn-sm">
                            Xem Thông Tin Phim
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mt-5 mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-lg text-white"
                 style="background: linear-gradient(45deg, #0d6efd, #6610f2); border-radius: 20px;">
                <div class="card-body p-5 text-center">
                    <div class="display-4 mb-3">🍿🥤</div>
                    <h2 class="fw-bold">COMBO BẮP NƯỚC SIÊU TIẾT KIỆM</h2>
                    <p class="lead opacity-75">Tiết kiệm đến 20% khi mua trực tuyến cùng vé xem phim!</p>
                    <a asp-controller="DichVu" asp-action="Index" class="btn btn-light btn-lg px-5 fw-bold text-primary mt-3 shadow">
                        XEM MENU DỊCH VỤ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }

    .btn-outline-primary:hover {
        background-color: #0d6efd;
        color: white;
        transform: scale(1.05);
        transition: 0.2s;
    }
</style>