@model IEnumerable<Cinema.DTO.PhimDTO>

@{
    ViewData["Title"] = "Lịch Chiếu Phim - Cinema";
}

<!-- HERO BANNER CHO PHIM -->
<div class="gsap-hero" style="min-height: 40vh; margin-bottom: 2rem;">
    <div class="gsap-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1536440136628-849c177e76a1?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');"></div>
    <div class="gsap-hero-overlay"></div>
    <div class="gsap-hero-content pt-5">
        <h1 class="gsap-hero-title mb-0" style="font-size: clamp(2rem, 4vw, 3.5rem);">
            <span class="line"><span class="line-inner text-white">LỊCH CHIẾU <span class="highlight">PHIM</span></span></span>
        </h1>
        <p class="gsap-hero-subtitle mt-3">Cập nhật những bộ phim mới nhất cùng các suất chiếu phù hợp với bạn</p>
    </div>
</div>

<div class="container mb-5">
    <!-- DATE SELECTOR -->
    <div class="d-flex justify-content-center flex-wrap mb-5 gap-3 gsap-reveal-scale">
        @for (int i = 0; i < 7; i++)
        {
            var d = DateTime.Today.AddDays(i);
            bool isActive = false;
            
            if (ViewBag.SelectedDate != null)
            {
                isActive = ((DateTime)ViewBag.SelectedDate).Date == d.Date;
            }
            else
            {
                isActive = i == 0;
            }

            var activeClass = isActive ? "active-date" : "";
            
            <a asp-action="Index" asp-route-date="@d.ToString("yyyy-MM-dd")" 
               class="btn gsap-date-pill px-4 py-2 text-center @activeClass">
                <div class="fs-5 fw-bold">@d.ToString("dd/MM")</div>
                <small class="d-block mt-1">
                    @(i == 0 ? "Hôm nay" : d.ToString("dddd", new System.Globalization.CultureInfo("vi-VN")))
                </small>
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="gsap-cta-banner gsap-reveal mx-auto" style="max-width: 800px;">
            <div class="display-1 text-muted mb-3"><i class="bi bi-calendar-x"></i></div>
            <h3 class="fw-bold text-white">Chưa có suất chiếu</h3>
            <p>Không có suất chiếu nào được lên lịch trong ngày này. Vui lòng chọn một ngày khác.</p>
        </div>
    }

    <!-- MOVIE SCHEDULE GRID -->
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="gsap-schedule-card h-100 d-flex flex-column">
                    <div class="gsap-movie-poster" style="height: 350px;">
                        @{
                            var imgUrl = string.IsNullOrEmpty(item.Poster)
                            ? "https://via.placeholder.com/300x400?text=No+Image"
                            : item.Poster.StartsWith("http") ? item.Poster : "/images/phim/" + item.Poster;
                        }
                        <img src="@imgUrl" alt="@item.TenPhim" onerror="this.onerror=null; this.src='https://via.placeholder.com/300x400?text=No+Image';">
                        <div class="gsap-movie-overlay">
                            <a asp-action="Details" asp-route-id="@item.MaPhim" class="btn-cinema-outline text-white border-white" style="padding: 8px 20px; font-size: 0.85rem;">
                                THÔNG TIN PHIM
                            </a>
                        </div>
                    </div>

                    <div class="card-body flex-grow-1 p-4">
                        <h5 class="card-title text-truncate" title="@item.TenPhim">@item.TenPhim</h5>
                        <p class="small mb-3"><i class="bi bi-tags-fill text-warning me-2"></i>@item.TheLoai</p>
                        
                        <div class="mt-4">
                            @if (item.DanhSachLichChieu != null && item.DanhSachLichChieu.Any())
                            {
                                <p class="small text-muted mb-2"><i class="bi bi-clock-history me-1"></i> Chọn suất chiếu:</p>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var suat in item.DanhSachLichChieu)
                                    {
                                        <a asp-controller="Phim" asp-action="ChonGhe" asp-route-maLich="@suat.MaLich"
                                           class="btn gsap-time-slot px-3 py-1">
                                            @suat.GioChieu
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-dark border border-secondary text-secondary px-3 py-2">
                                    <i class="bi bi-info-circle me-1"></i> Sắp có suất chiếu
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- PROMO BANNER -->
    <div class="row mt-5 pt-5 gsap-reveal">
        <div class="col-12">
            <div class="gsap-cta-banner p-5">
                <div class="display-3 mb-3">🍿🥤</div>
                <h2 class="mb-2">COMBO BẮP NƯỚC ƯU ĐÃI</h2>
                <p class="mb-4 text-white">Đặt vé và mua kèm combo trực tuyến để tiết kiệm tới 20%</p>
                <a asp-controller="DichVu" asp-action="Index" class="btn-cinema-primary">
                    <i class="bi bi-cart-plus me-2"></i>ĐẶT DỊCH VỤ NGAY
                </a>
            </div>
        </div>
    </div>
</div>