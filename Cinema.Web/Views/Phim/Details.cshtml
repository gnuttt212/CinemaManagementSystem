@model Cinema.DTO.PhimDTO

@{
    ViewData["Title"] = Model.TenPhim;
}

<div class="container mt-5 pt-4 mb-5">
    <!-- BREADCRUMB -->
    <nav aria-label="breadcrumb" class="gsap-reveal-left mb-4">
        <ol class="breadcrumb gsap-breadcrumb m-0">
            <li class="breadcrumb-item"><a asp-action="Index"><i class="bi bi-house-door me-1"></i>Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Lịch chiếu</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenPhim</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- POSTER (Left) -->
        <div class="col-md-4 gsap-reveal-left">
            <div class="gsap-detail-poster position-sticky" style="top: 100px;">
                <img src="@(string.IsNullOrEmpty(Model.Poster) ? $"https://via.placeholder.com/400x600?text={Model.TenPhim}" : Model.Poster.StartsWith("http") ? Model.Poster : $"/images/phim/{Model.Poster}")"
                     alt="@Model.TenPhim" onerror="this.onerror=null; this.src='https://via.placeholder.com/400x600?text=No+Image';">
            </div>
        </div>

        <!-- DETAILS (Right) -->
        <div class="col-md-8 gsap-reveal-right">
            <div class="gsap-detail-info">
                <h1>@Model.TenPhim</h1>
                
                <div class="d-flex flex-wrap gap-4 mt-3 mb-4 gsap-detail-meta">
                    <span>
                        <i class="bi bi-clock-history text-primary"></i>
                        <strong>@Model.ThoiLuong phút</strong>
                    </span>
                    <span>
                        <i class="bi bi-tags-fill text-warning"></i>
                        <strong>@(Model.TheLoai ?? "N/A")</strong>
                    </span>
                    <span>
                        <i class="bi bi-camera-reels text-info"></i>
                        <strong>@(Model.DaoDien ?? "N/A")</strong>
                    </span>
                    @if (Model.NgayKhoiChieu.HasValue)
                    {
                        <span>
                            <i class="bi bi-calendar-event text-success"></i>
                            <strong>@Model.NgayKhoiChieu.Value.ToString("dd/MM/yyyy")</strong>
                        </span>
                    }
                </div>

                <hr class="my-4">

                <div class="gsap-detail-synopsis mb-5">
                    <h5 class="mb-3"><i class="bi bi-card-text me-2 text-primary"></i>Nội dung phim</h5>
                    <p class="m-0 lh-lg text-justify">
                        @(string.IsNullOrEmpty(Model.MoTa) ? "Thông tin mô tả phim đang được cập nhật..." : Model.MoTa)
                    </p>
                </div>

                <h3 class="gsap-section-title mt-5">CHỌN SUẤT CHIẾU</h3>
                
                <div class="d-flex flex-wrap gap-3 mt-4 mb-5">
                    @if (Model.LichChieus != null && Model.LichChieus.Any())
                    {
                        @foreach (var suat in Model.LichChieus)
                        {
                            <button type="button"
                                    class="btn gsap-showtime-btn"
                                    data-id="@suat.MaLich">
                                <i class="bi bi-play-circle me-1"></i> @(suat.GioChieu.HasValue ? suat.GioChieu.Value.ToString(@"hh\:mm") : "N/A")
                            </button>
                        }
                    }
                    else
                    {
                        <div class="gsap-feature-card w-100 text-start p-4">
                            <h5 class="text-warning mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Chưa có suất chiếu</h5>
                            <p class="m-0">Hiện chưa có suất chiếu nào cho phim này. Vui lòng quay lại sau!</p>
                        </div>
                    }
                </div>

                <div class="mt-4 pt-2 border-top border-secondary">
                    <a id="btnDatVe" href="javascript:void(0)" onclick="checkSelection()"
                       class="btn-cinema-primary w-100 d-block text-center py-3 fs-5 mt-4" style="text-decoration: none;">
                        <i class="bi bi-ticket-perforated-fill me-2"></i> ĐẶT VÉ NGAY
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.gsap-showtime-btn').click(function () {
                // Animate selection with GSAP
                gsap.to('.gsap-showtime-btn', { scale: 1, duration: 0.2 });
                gsap.to(this, { scale: 1.05, duration: 0.3, ease: 'back.out(1.5)' });

                $('.gsap-showtime-btn').removeClass('active');
                $(this).addClass('active');

                let maLich = $(this).data('id');
                $('#btnDatVe').attr('data-selected-id', maLich);
                $('#btnDatVe').attr('href', '/Phim/ChonGhe?maLich=' + maLich);
                
                // Pulse CTA
                gsap.fromTo('#btnDatVe', 
                    { scale: 1 }, 
                    { scale: 1.02, duration: 0.4, yoyo: true, repeat: 1, ease: 'power2.inOut', boxShadow: '0 0 30px rgba(229, 9, 20, 0.6)' }
                );
            });
        });

        function checkSelection() {
            let selectedId = $('#btnDatVe').attr('data-selected-id');
            let finalHref = $('#btnDatVe').attr('href');

            if (!selectedId || finalHref === "javascript:void(0)") {
                // Shake animation for error
                gsap.to('#btnDatVe', {
                    x: [-10, 10, -10, 10, 0],
                    duration: 0.4,
                    ease: 'power1.inOut'
                });
                
                // Show custom toast/alert instead of native alert
                const alertHtml = `
                    <div id="cinemaAlert" class="position-fixed top-0 start-50 translate-middle-x mt-5 p-3 rounded" 
                         style="background: var(--cinema-card); border: 1px solid var(--cinema-primary); z-index: 1050; opacity: 0;">
                        <div class="d-flex align-items-center text-white">
                            <i class="bi bi-exclamation-circle text-primary fs-4 me-3"></i>
                            <div>Vui lòng chọn một suất chiếu để tiếp tục!</div>
                        </div>
                    </div>
                `;
                $('body').append(alertHtml);
                
                const tl = gsap.timeline();
                tl.to('#cinemaAlert', { y: 20, opacity: 1, duration: 0.4, ease: 'back.out' })
                  .to('#cinemaAlert', { y: 0, opacity: 0, duration: 0.4, delay: 2.5, ease: 'power2.in', onComplete: () => $('#cinemaAlert').remove() });
            } else {
                window.location.href = finalHref;
            }
        }
    </script>
}