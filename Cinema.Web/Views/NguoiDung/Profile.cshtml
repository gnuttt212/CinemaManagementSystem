@model Cinema.DTO.KhachHangDTO

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0 rounded-4 p-3">
                <div class="card-body text-center">
                    <img src="https://ui-avatars.com/api/?name=@Model.HoTen&background=0D6EFD&color=fff&size=128"
                         class="rounded-circle shadow mb-3" alt="Avatar" width="120">

                    <h4 class="fw-bold text-uppercase">@Model.HoTen</h4>
                    <p class="text-muted mb-4">@@@Model.TaiKhoan</p>

                    <div class="text-start bg-light p-3 rounded-3">
                        <p class="mb-2 border-bottom pb-2">
                            <i class="bi bi-envelope-at-fill text-primary me-2"></i>
                            <strong>Email:</strong> <br />
                            <span class="text-break">@Model.Email</span>
                        </p>
                        <p class="mb-2 border-bottom pb-2">
                            <i class="bi bi-telephone-fill text-success me-2"></i>
                            <strong>SĐT:</strong> <br />
                            <span>@(Model.SDT ?? "Chưa cập nhật")</span>
                        </p>
                        <p class="mb-0">
                            <i class="bi bi-star-fill text-warning me-2"></i>
                            <strong>Điểm tích lũy:</strong> <br />
                            <span class="fw-bold text-primary">@Model.DiemTichLuy điểm</span>
                        </p>
                    </div>

                    <a asp-controller="NguoiDung" asp-action="EditProfile" class="btn btn-outline-primary w-100 mt-4 rounded-pill fw-bold mb-2">
                        <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa hồ sơ
                    </a>
                    <a asp-controller="NguoiDung" asp-action="DoiMatKhau" class="btn btn-warning w-100 rounded-pill fw-bold shadow-sm text-dark">
                        <i class="bi bi-shield-lock-fill me-2"></i> Đổi Mật Khẩu
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-ticket-perforated-fill me-2 text-danger"></i>LỊCH SỬ ĐẶT VÉ
                    </h4>
                    <span class="badge bg-secondary rounded-pill">@Model.LichSuHoaDon?.Count giao dịch</span>
                </div>
                <div class="card-body">
                    @if (Model.LichSuHoaDon != null && Model.LichSuHoaDon.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light text-uppercase small fw-bold text-muted">
                                    <tr>
                                        <th>Mã HD</th>
                                        <th>Thời gian</th>
                                        <th class="text-end">Tổng tiền</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hd in Model.LichSuHoaDon.OrderByDescending(x => x.NgayDat))
                                    {
                                        <tr>
                                            <td class="fw-bold">#@hd.MaHD</td>
                                            <td>
                                                <div class="fw-bold">@hd.NgayDat?.ToString("dd/MM/yyyy")</div>
                                                <div class="small text-muted">@hd.NgayDat?.ToString("HH:mm")</div>
                                            </td>
                                            <td class="text-end text-danger fw-bold">
                                                @hd.TongTien?.ToString("N0") đ
                                            </td>
                                            <td class="text-center">
                                                @{
                                                    var badgeClass = hd.TrangThai == "Đã thanh toán" 
                                                        ? "bg-success-subtle text-success border-success-subtle" 
                                                        : "bg-warning-subtle text-warning border-warning-subtle";
                                                }
                                                <span class="badge @badgeClass border rounded-pill px-3">@(hd.TrangThai ?? "N/A")</span>
                                            </td>
                                            <td class="text-center">
                                                <a asp-controller="HoaDon" asp-action="ThanhToanThanhCong" asp-route-id="@hd.MaHD"
                                                   class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                                    <i class="bi bi-qr-code-scan"></i> Xem vé
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x text-muted display-1"></i>
                            <p class="mt-3 text-muted fs-5">Bạn chưa thực hiện giao dịch nào.</p>
                            <a asp-controller="Phim" asp-action="Index" class="btn btn-primary rounded-pill px-4 shadow">
                                <i class="bi bi-play-circle me-2"></i>Đặt vé ngay
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }

            .card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            }

        .table thead th {
            border-bottom: none;
            letter-spacing: 0.5px;
        }

        .badge {
            font-weight: 500;
        }

        tbody tr:first-child {
            background-color: rgba(13, 110, 253, 0.03);
        }
    </style>
}