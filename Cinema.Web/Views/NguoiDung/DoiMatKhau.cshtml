@model Cinema.DTO.DoiMatKhauRequest

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0 rounded-4 p-4">
            <h3 class="fw-bold mb-4 text-center text-primary">
                <i class="bi bi-shield-lock me-2"></i> ĐỔI MẬT KHẨU
            </h3>

            <p class="text-muted text-center mb-4">
                Vui lòng nhập mật khẩu hiện tại và tạo mật khẩu mới an toàn hơn.
            </p>

            <form asp-action="DoiMatKhau" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                        <input type="password" class="form-control" asp-for="MatKhauHienTai" required placeholder="Nhập mật khẩu cũ..." />
                    </div>
                    <span asp-validation-for="MatKhauHienTai" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control" asp-for="MatKhauMoi" required placeholder="Tối thiểu 6 ký tự..." />
                    </div>
                    <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-shield-check"></i></span>
                        <input type="password" class="form-control" asp-for="XacNhanMatKhau" required placeholder="Nhập lại mật khẩu mới..." />
                    </div>
                    <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger border-0 border-start border-4 border-danger py-2">
                        @Html.ValidationSummary(true, "", new { @class = "mb-0 fw-bold" })
                    </div>
                }

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Profile" class="btn btn-outline-secondary px-4 rounded-pill">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold shadow-sm">
                        Cập nhật mật khẩu <i class="bi bi-check2 ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
