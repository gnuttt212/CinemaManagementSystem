@model List<Cinema.DTO.PhimDTO>
@{
    ViewData["Title"] = "Trang Chủ - Cinema.Web";
}

<!-- ═══ HERO SECTION ═══ -->
<div class="gsap-hero">
    <div class="gsap-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');"></div>
    <div class="gsap-hero-overlay"></div>

    <div class="glow-orb glow-orb-red"></div>
    <div class="glow-orb glow-orb-gold"></div>

    <div class="gsap-hero-content">
        <h1 class="gsap-hero-title">
            <span class="line"><span class="line-inner">HÀNH TRÌNH ĐIỆN ẢNH</span></span>
            <span class="line"><span class="line-inner"><span class="highlight">BẮT ĐẦU TẠI ĐÂY</span></span></span>
        </h1>
        <p class="gsap-hero-subtitle">
            Trải nghiệm những bộ phim bom tấn mới nhất với chất lượng âm thanh và hình ảnh đỉnh cao.
        </p>
        <div class="gsap-hero-cta">
            <a asp-controller="Phim" asp-action="Index" class="btn-cinema-primary">
                <i class="bi bi-ticket-perforated-fill me-2"></i>ĐẶT VÉ NGAY
            </a>
            <a asp-controller="Home" asp-action="Privacy" class="btn-cinema-outline">
                Tìm hiểu thêm
            </a>
        </div>
    </div>

    <div class="scroll-indicator">
        <div class="mouse"><div class="wheel"></div></div>
    </div>
</div>

<!-- ═══ FEATURES ═══ -->
<div class="container my-5 py-4">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="gsap-feature-card h-100">
                <div class="gsap-feature-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <h4>Đặt vé cực nhanh</h4>
                <p>Chỉ với vài click chuột, bạn đã sở hữu ngay chỗ ngồi ưng ý nhất.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="gsap-feature-card h-100">
                <div class="gsap-feature-icon" style="background: rgba(245,197,24,0.1); color: var(--cinema-accent); border-color: rgba(245,197,24,0.2);">
                    <i class="bi bi-popcorn-fill"></i>
                </div>
                <h4>Combo đa dạng</h4>
                <p>Thỏa sức lựa chọn bắp nước với các combo ưu đãi đặc biệt.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="gsap-feature-card h-100">
                <div class="gsap-feature-icon" style="background: rgba(40,167,69,0.1); color: #28a745; border-color: rgba(40,167,69,0.2);">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4>Thanh toán an toàn</h4>
                <p>Hệ thống bảo mật tuyệt đối, hỗ trợ nhiều hình thức thanh toán.</p>
            </div>
        </div>
    </div>
</div>

<!-- ═══ NOW SHOWING ═══ -->
<div class="container my-5 py-3">
    <div class="d-flex justify-content-between align-items-end mb-4 gsap-reveal">
        <div>
            <h2 class="gsap-section-title">Phim Đang Chiếu</h2>
            <p class="gsap-section-sub">Đừng bỏ lỡ những siêu phẩm điện ảnh mới nhất</p>
        </div>
        <a asp-controller="Phim" asp-action="Index" class="btn-cinema-outline" style="padding: 8px 24px; font-size: 0.9rem;">
            Xem tất cả <i class="bi bi-chevron-right"></i>
        </a>
    </div>

    <div class="row mb-5 gsap-reveal">
        <div class="col-md-6 mx-auto">
            <form asp-controller="Phim" asp-action="Search" method="get" class="gsap-search input-group">
                <input type="text" name="query" class="form-control py-3 ps-4" placeholder="Tìm tên phim, thể loại...">
                <button class="btn px-4" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var phim in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="gsap-movie-card h-100">
                    <div class="gsap-movie-poster">
                        @{
                            var posterUrl = string.IsNullOrEmpty(phim.Poster)
                                ? "https://via.placeholder.com/300x400?text=No+Image"
                                : phim.Poster.StartsWith("http") ? phim.Poster : "/images/phim/" + phim.Poster;
                        }
                        <img src="@posterUrl" alt="@phim.TenPhim" onerror="this.onerror=null; this.src='https://via.placeholder.com/300x400?text=No+Image';">
                        <div class="gsap-movie-overlay">
                            <a asp-controller="Phim" asp-action="Details" asp-route-id="@phim.MaPhim" class="btn-cinema-primary" style="padding: 10px 28px; font-size: 0.85rem;">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>
                    <div class="gsap-movie-body">
                        <h6 class="text-truncate">@phim.TenPhim</h6>
                        <div class="gsap-movie-meta">
                            <span class="badge">@phim.TheLoai</span>
                            <small><i class="bi bi-clock me-1"></i>@phim.ThoiLuong'</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>